# ── TUI App ─────────────────────────────────────────────────────────────────

class E3cncTui(App):
    """E3CNC UI management TUI."""

    BUTTON_ROWS = [
        ["btn-status", "btn-install", "btn-deploy", "btn-update"],
        ["btn-uninstall", "btn-check", "btn-backup", "btn-restore"],
        ["btn-diagnose", "btn-logs", "btn-exit"],
    ]

    TITLE = "E3CNC UI Manager"
    CSS = CSS
    BINDINGS = [
        ("ctrl+c", "quit", "Quit"),
        ("escape", "focus_button_grid", "Buttons"),
        ("f5", "refresh_status", "Refresh Status"),
        ("up", "move_up", "Up"),
        ("down", "move_down", "Down"),
        ("left", "move_left", "Left"),
        ("right", "move_right", "Right"),
    ]

    status_text = reactive("Ready")
    status_class = reactive("status-idle")
    running = reactive(False)

    # ── Screen setup ────────────────────────────────────────────────────────

    def compose(self) -> ComposeResult:
        # Banner
        yield Static(BANNER_RAW, id="banner")
        yield Static(f"  {TOOL_NAME} v{VERSION}  —  Terminal UI", id="title-bar")

        # Main area: buttons + options + output
        with Container(id="main-area"):
            # Button grid
            with Horizontal(id="button-grid"):
                yield Button("[S] Status", id="btn-status", variant="primary")
                yield Button("[I] Install", id="btn-install", variant="primary")
                yield Button("[D] Deploy", id="btn-deploy", variant="primary")
                yield Button("[U] Update", id="btn-update", variant="primary")
                yield Button("[X] Uninstall", id="btn-uninstall", variant="error")
                yield Button("[C] Check Deps", id="btn-check", variant="default")
                yield Button("[B] Backup", id="btn-backup", variant="default")
                yield Button("[R] Restore", id="btn-restore", variant="default")
                yield Button("[G] Diagnose", id="btn-diagnose", variant="default")
                yield Button("[L] Logs", id="btn-logs", variant="default")
                yield Button("[Q] Exit", id="btn-exit", variant="error")

            # Output panel
            with Container(id="output-panel"):
                yield Label(" Output")
                yield RichLog(id="command-output", highlight=True, markup=True, wrap=True)

        # Footer
        yield Static(id="status-bar")

    def on_mount(self) -> None:
        """Set up initial state."""
        self._update_status("Ready — press a button to start", "status-idle")
        self.query_one("#command-output", RichLog).write(
            "[dim]Welcome to E3CNC UI Manager[/]\n"
            "[dim]Use arrow keys to navigate buttons.[/]\n"
            "[dim]Press Enter to run the focused action.[/]\n"
        )
        self.action_focus_button_grid()

    # ── Helpers ─────────────────────────────────────────────────────────────

    def _get_remote(self) -> Optional[str]:
        return None

    def _get_check_mode(self) -> bool:
        return False

    def _get_verbose(self) -> bool:
        return False

    def _get_log_lines(self) -> int:
        return 50

    def _update_status(self, text: str, css_class: str = "status-idle") -> None:
        self.status_text = text
        self.status_class = css_class
        try:
            bar = self.query_one("#status-bar", Static)
            bar.update(f"[{css_class}]{text}[/]")
        except NoMatches:
            pass

    def _get_output(self) -> RichLog:
        return self.query_one("#command-output", RichLog)

    def _output_callback(self, line: str) -> None:
        """Called by command functions for each line of output."""
        self.call_from_thread(self._get_output().write, line)

    def _disable_buttons(self, disabled: bool = True) -> None:
        """Enable/disable all command buttons."""
        for row in self.BUTTON_ROWS:
            for btn_id in row:
                try:
                    self.query_one(f"#{btn_id}", Button).disabled = disabled
                except NoMatches:
                    pass

    def _focused_button_id(self) -> Optional[str]:
        focused = self.focused
        if isinstance(focused, Button):
            return focused.id
        return None

    def _focus_button(self, button_id: str) -> None:
        try:
            self.query_one(f"#{button_id}", Button).focus()
        except NoMatches:
            pass

    def _find_button_position(self, button_id: str) -> Optional[tuple[int, int]]:
        for row_index, row in enumerate(self.BUTTON_ROWS):
            for col_index, current_id in enumerate(row):
                if current_id == button_id:
                    return row_index, col_index
        return None

    def _move_focus(self, row_delta: int = 0, col_delta: int = 0) -> None:
        if self.running:
            return

        button_id = self._focused_button_id()
        if button_id is None:
            self.action_focus_button_grid()
            return

        pos = self._find_button_position(button_id)
        if pos is None:
            self.action_focus_button_grid()
            return

        row_index, col_index = pos
        target_row_index = max(0, min(len(self.BUTTON_ROWS) - 1, row_index + row_delta))

        if row_delta != 0:
            target_row = self.BUTTON_ROWS[target_row_index]
            target_col_index = max(0, min(len(target_row) - 1, col_index))
        else:
            target_row = self.BUTTON_ROWS[row_index]
            target_row_index = row_index
            target_col_index = max(0, min(len(target_row) - 1, col_index + col_delta))

        self._focus_button(self.BUTTON_ROWS[target_row_index][target_col_index])

    # ── Action: Refresh Status ──────────────────────────────────────────────

    @work(thread=True)
    def action_refresh_status(self) -> None:
        """Quick status check (bound to F5)."""
        self.call_from_thread(self._update_status, "Checking status...", "status-idle")
        self.call_from_thread(self._get_output().clear)
        remote = self._get_remote()
        ok_count, total, lines = check_status(remote)
        for line in lines:
            self._output_callback(line + "\n")
        if ok_count == total:
            self.call_from_thread(self._update_status,
                                  f"✓ All {total} components installed", "status-ok")
        else:
            self.call_from_thread(self._update_status,
                                  f"⚠ {ok_count}/{total} components installed", "status-warn")

    # ── Command dispatcher ──────────────────────────────────────────────────

    def _run_command(self, command_name: str, label: str) -> None:
        """Run a command asynchronously with button disabling."""
        if self.running:
            return

        self.running = True
        self._disable_buttons(True)
        self._get_output().clear()
        self._update_status(f"Running {label}...", "status-idle")

        # Dispatch to the right handler
        dispatch = {
            "status": self._cmd_status,
            "install": self._cmd_install,
            "deploy": self._cmd_deploy,
            "update": self._cmd_update,
            "uninstall": self._cmd_uninstall,
            "check": self._cmd_check,
            "backup": self._cmd_backup,
            "restore": self._cmd_restore,
            "diagnose": self._cmd_diagnose,
            "logs": self._cmd_logs,
        }
        handler = dispatch.get(command_name)
        if handler:
            handler()
        else:
            self._get_output().write(f"[red]Unknown command: {command_name}[/]")
            self._finish_command(False, label)

    def _finish_command(self, success: bool, label: str) -> None:
        """Re-enable buttons and update status after a command finishes."""
        self.running = False
        self._disable_buttons(False)
        if success:
            self._update_status(f"✓ {label} completed", "status-ok")
        else:
            self._update_status(f"✗ {label} failed — see output above", "status-err")

    # ── Individual command implementations ──────────────────────────────────

    @work(thread=True)
    def _cmd_status(self) -> None:
        remote = self._get_remote()
        ok_count, total, lines = check_status(remote)
        for line in lines:
            self._output_callback(line + "\n")
        success = ok_count == total
        self.call_from_thread(self._finish_command, success, "Status")

    @work(thread=True)
    def _cmd_install(self) -> None:
        result = run_ansible_playbook(
            INSTALL_PLAYBOOK, self._get_remote(),
            self._get_check_mode(), self._get_verbose(),
            "Install", output_callback=self._output_callback,
        )
        self.call_from_thread(self._finish_command, result.success, "Install")

    @work(thread=True)
    def _cmd_deploy(self) -> None:
        result = run_ansible_playbook(
            DEPLOY_PLAYBOOK, self._get_remote(),
            self._get_check_mode(), self._get_verbose(),
            "Deploy", output_callback=self._output_callback,
        )
        self.call_from_thread(self._finish_command, result.success, "Deploy")

    @work(thread=True)
    def _cmd_update(self) -> None:
        result = run_ansible_playbook(
            REDEPLOY_PLAYBOOK, self._get_remote(),
            self._get_check_mode(), self._get_verbose(),
            "Update", output_callback=self._output_callback,
        )
        self.call_from_thread(self._finish_command, result.success, "Update")

    @work(thread=True)
    def _cmd_uninstall(self) -> None:
        result = run_ansible_playbook(
            UNINSTALL_PLAYBOOK, self._get_remote(),
            self._get_check_mode(), self._get_verbose(),
            "Uninstall", output_callback=self._output_callback,
        )
        self.call_from_thread(self._finish_command, result.success, "Uninstall")

    @work(thread=True)
    def _cmd_check(self) -> None:
        all_ok, _ = check_dependencies(output_callback=self._output_callback)
        self.call_from_thread(self._finish_command, all_ok, "Check")

    @work(thread=True)
    def _cmd_backup(self) -> None:
        result = run_backup(self._get_remote(), output_callback=self._output_callback)
        self.call_from_thread(self._finish_command, result.success, "Backup")

    @work(thread=True)
    def _cmd_restore(self) -> None:
        # Grab backup dir from the output area / a prompt
        # For now, re-use a simple approach: prompt via input
        # Since Textual doesn't have a built-in prompt, we show instructions
        self._output_callback(
            "[yellow]To restore, run: e3cnc-cli restore <backup-dir>[/]\n"
            "[yellow]Or type the backup directory name below and press Restore again.[/]\n"
        )
        # Fallback: use the shared function with empty dir — will fail gracefully
        result = run_restore(
            "", self._get_remote(), True,
            output_callback=self._output_callback,
        )
        self.call_from_thread(self._finish_command, result.success, "Restore")

    @work(thread=True)
    def _cmd_diagnose(self) -> None:
        result = run_diagnose(self._get_remote(), output_callback=self._output_callback)
        self.call_from_thread(self._finish_command, result.success, "Diagnose")

    @work(thread=True)
    def _cmd_logs(self) -> None:
        result = run_logs(self._get_remote(), self._get_log_lines(),
                          output_callback=self._output_callback)
        self.call_from_thread(self._finish_command, result.success, "Logs")

    # ── Event handlers ──────────────────────────────────────────────────────

    def on_button_pressed(self, event: Button.Pressed) -> None:
        """Handle button presses."""
        btn_id = event.button.id or ""
        command_map = {
            "btn-status": "status",
            "btn-install": "install",
            "btn-deploy": "deploy",
            "btn-update": "update",
            "btn-uninstall": "uninstall",
            "btn-check": "check",
            "btn-backup": "backup",
            "btn-restore": "restore",
            "btn-diagnose": "diagnose",
            "btn-logs": "logs",
            "btn-exit": "exit",
        }
        command = command_map.get(btn_id)
        if command == "exit":
            self.exit()
        elif command:
            label_map = {
                "status": "Status Check", "install": "Install",
                "deploy": "Deploy", "update": "Update",
                "uninstall": "Uninstall", "check": "Dependency Check",
                "backup": "Backup", "restore": "Restore",
                "diagnose": "Diagnostics", "logs": "Logs",
            }
            self._run_command(command, label_map.get(command, command))

    def action_focus_button_grid(self) -> None:
        """Focus the first button (bound to Escape)."""
        self._focus_button("btn-status")

    def action_move_up(self) -> None:
        self._move_focus(row_delta=-1)

    def action_move_down(self) -> None:
        self._move_focus(row_delta=1)

    def action_move_left(self) -> None:
        self._move_focus(col_delta=-1)

    def action_move_right(self) -> None:
        self._move_focus(col_delta=1)

    def watch_status_text(self, text: str) -> None:
        """Reactively update the status bar."""
        pass  # Handled in _update_status

    def watch_status_class(self, cls: str) -> None:
        """Reactively update the status bar class."""
        pass  # Handled in _update_status


# ── Entry point ─────────────────────────────────────────────────────────────

def main() -> None:
    app = E3cncTui()
    app.run()


if __name__ == "__main__":
    main()
