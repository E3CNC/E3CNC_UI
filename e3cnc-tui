#!/usr/bin/env python3
"""
e3cnc-tui — Terminal User Interface for E3CNC UI management.

A Textual-based TUI that wraps the command logic from _e3cnc_shared.py
with an interactive button grid, options panel, and live output display.

Usage:
    e3cnc-tui          # Launch the TUI

Textual is auto-installed on first run if missing.
"""

import importlib
import subprocess
import sys

# ── Self-bootstrap: auto-install textual if missing ────────────────────────

def _ensure_textual() -> None:
    """Check if textual is installed; if not, install it via pip."""
    try:
        import textual  # noqa: F401
    except ImportError:
        print("\n  E3CNC TUI requires the 'textual' library.")
        print("  Installing it now...")
        sys.stdout.flush()
        result = subprocess.run(
            [sys.executable, "-m", "pip", "install", "textual", "--quiet"],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            print(f"\n  Failed to install textual: {result.stderr}")
            print("  Try manually: pip install textual")
            sys.exit(1)
        # Force reimport
        importlib.invalidate_caches()
        try:
            import textual  # noqa: F401
        except ImportError:
            print("\n  textual was installed but cannot be imported.")
            print("  Try restarting your terminal, or run: pip install textual")
            sys.exit(1)
        print("  ✓ textual installed successfully\n")


_ensure_textual()


