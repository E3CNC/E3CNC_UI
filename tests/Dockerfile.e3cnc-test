# Dockerfile.e3cnc-test
# E3CNC test container with SSH access for manual testing.
#
# Build:
#   docker build -t e3cnc-test -f tests/Dockerfile.e3cnc-test .
#
# Run:
#   docker run -d --rm --name e3cnc-test -p 2222:22 e3cnc-test
#
# SSH (password: testbed):
#   ssh testbed@localhost -p 2222
#
# Inside the container:
#   cd ~/E3CNC
#   ./e3cnc-cli install --name mymachine

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    sudo \
    ca-certificates \
    socat \
    openssh-server \
    libsodium23 \
    avahi-utils \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages ansible

RUN useradd -m -s /bin/bash testbed && \
    echo "testbed:testbed" | chpasswd && \
    echo "testbed ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# SSH config
RUN mkdir /var/run/sshd && \
    sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' /etc/ssh/sshd_config && \
    sed -i 's/#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config

COPY --chown=testbed:testbed . /home/testbed/E3CNC

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D"]
