#!/usr/bin/env python3
"""
e3cnc-cli — Unified CLI for installing, deploying, and managing E3CNC UI.

This tool wraps the project's Ansible playbooks and utility scripts into a
single, user-friendly command-line interface. It runs on both the CNC host
(Klipper/Moonraker) and development machines.

Quick start:
    e3cnc-cli check             # verify dependencies
    e3cnc-cli install           # full install (agent, frontend, plugins)
    e3cnc-cli deploy            # deploy frontend only
    e3cnc-cli update            # re-vendor agent, rebuild frontend, restart
    e3cnc-cli status            # check installation status
    e3cnc-cli uninstall         # remove all E3CNC components
    e3cnc-cli backup            # create a timestamped backup
    e3cnc-cli restore BACKUP_DIR  # restore from a backup

Use --check for dry-run mode, --remote for remote hosts, and --verbose for
detailed output.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import NoReturn

# ── Metadata ────────────────────────────────────────────────────────────────

VERSION = "0.7.4"
TOOL_NAME = "e3cnc-cli"

# ── Paths (relative to this script's location) ─────────────────────────────

HERE = Path(__file__).resolve().parent
ANSIBLE_DIR = HERE / "ansible"
PLAYBOOKS_DIR = ANSIBLE_DIR / "playbooks"
SCRIPTS_DIR = HERE / "scripts"

INSTALL_PLAYBOOK = PLAYBOOKS_DIR / "install.yml"
DEPLOY_PLAYBOOK = PLAYBOOKS_DIR / "deploy.yml"
UNINSTALL_PLAYBOOK = PLAYBOOKS_DIR / "uninstall.yml"
REDEPLOY_PLAYBOOK = PLAYBOOKS_DIR / "redeploy.yml"
LOCAL_INVENTORY = ANSIBLE_DIR / "inventory" / "local.yml"

DOWNLOAD_FRONTEND_SCRIPT = SCRIPTS_DIR / "download_frontend.sh"
BACKUP_SCRIPT = SCRIPTS_DIR / "restore_backup.sh"  # not used, we implement inline

DEFAULT_REMOTE_INVENTORY = ANSIBLE_DIR / "inventory" / "remote.yml"

# ── Colors / Styling ────────────────────────────────────────────────────────

def _style_enabled():
    return sys.stdout.isatty() and os.name != "nt"


_STYLE = _style_enabled()


def _sc(code: str) -> str:
    return f"\033[{code}m" if _STYLE else ""


class Style:
    """Minimal terminal styling — degrades gracefully when piped or on Windows."""
    GREEN = _sc("32")
    CYAN = _sc("36")
    YELLOW = _sc("33")
    RED = _sc("31")
    BOLD = _sc("1")
    DIM = _sc("2")
    RESET = _sc("0")


def ok(msg: str) -> None:
    print(f"  {Style.GREEN}✓{Style.RESET} {msg}")


def info(msg: str) -> None:
    print(f"  {Style.CYAN}→{Style.RESET} {msg}")


def warn(msg: str) -> None:
    print(f"  {Style.YELLOW}⚠{Style.RESET} {msg}", file=sys.stderr)


def fail(msg: str, code: int = 1) -> NoReturn:
    print(f"\n  {Style.RED}✗{Style.RESET} {msg}", file=sys.stderr)
    sys.exit(code)


def step(num: int, total: int, label: str) -> None:
    print(f"\n  {Style.BOLD}[{num}/{total}]{Style.RESET} {label}")


def header(title: str) -> None:
    print(f"\n  {Style.BOLD}{Style.GREEN}{TOOL_NAME}{Style.RESET} — {title}\n")
    print(f"  {Style.DIM}Repository root: {HERE}{Style.RESET}")


# ── Ansible helpers ─────────────────────────────────────────────────────────

def _build_ansible_cmd(
    playbook: Path,
    inventory: Path,
    *,
    check: bool = False,
    verbose: bool = False,
    extra_vars: list[str] | None = None,
) -> list[str]:
    """Build an ansible-playbook command with common flags."""
    cmd = ["ansible-playbook"]
    cmd.extend(["-i", str(inventory)])
    cmd.append(str(playbook))
    if check:
        cmd.append("--check")
    if verbose:
        cmd.append("-v")
    if extra_vars:
        for ev in extra_vars:
            cmd.extend(["-e", ev])
    return cmd


def run_ansible(
    playbook: Path,
    inventory: Path,
    *,
    check: bool = False,
    verbose: bool = False,
    extra_vars: list[str] | None = None,
) -> int:
    """Run an Ansible playbook and stream output."""
    cmd = _build_ansible_cmd(
        playbook, inventory, check=check, verbose=verbose, extra_vars=extra_vars
    )
    print(f"\n  {Style.DIM}$ {' '.join(cmd)}{Style.RESET}\n")
    result = subprocess.run(cmd, cwd=ANSIBLE_DIR)
    return result.returncode


# ── Dependency checks ───────────────────────────────────────────────────────

def _check_command(name: str, hint: str = "") -> bool:
    """Return True if `name` is found on PATH."""
    found = shutil.which(name) is not None
    if found:
        ok(f"{name} found")
    else:
        missing_hint = f"  {hint}" if hint else ""
        warn(f"{name} not found" + (f"\n{missing_hint}" if missing_hint else ""))
    return found


def _check_python_module(module: str) -> bool:
    """Return True if a Python module can be imported."""
    try:
        __import__(module)
        ok(f"Python module: {module}")
        return True
    except ImportError:
        warn(f"Python module: {module} not found")
        return False


def cmd_check(args: argparse.Namespace) -> None:
    """Check that all required dependencies are available."""
    header("Dependency Check")

    all_ok = True

    print(f"\n  {Style.BOLD}Core tools{Style.RESET}")
    all_ok &= _check_command("git")
    all_ok &= _check_command("python3", hint="Install Python 3: sudo apt install python3")
    all_ok &= _check_command("curl")
    all_ok &= _check_command("unzip")
    all_ok &= _check_command("rsync")

    print(f"\n  {Style.BOLD}Ansible{Style.RESET}")
    has_ansible = _check_command(
        "ansible-playbook",
        hint="Install: pip3 install ansible --user",
    )
    if has_ansible:
        ansible_ver = subprocess.run(
            ["ansible-playbook", "--version"], capture_output=True, text=True
        ).stdout.splitlines()[0]
        info(f"ansible-playbook version: {ansible_ver.strip()}")

        # Check community.general collection
        result = subprocess.run(
            [sys.executable, "-c", "import ansible_collections.community.general"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0:
            ok("Ansible collection: community.general")
        else:
            warn("Ansible collection: community.general not found — install with: ansible-galaxy collection install community.general")
            all_ok = False

    print(f"\n  {Style.BOLD}Node.js / Frontend{Style.RESET}")
    has_bun = _check_command("bun", hint="Install: curl -fsSL https://bun.sh/install | bash")
    has_node = _check_command("node", hint="Install via nvm: nvm install 20")
    all_ok &= has_bun or has_node  # at least one is needed

    print(f"\n  {Style.BOLD}Project structure{Style.RESET}")
    if PLAYBOOKS_DIR.is_dir():
        ok(f"Ansible playbooks at {PLAYBOOKS_DIR}")
    else:
        warn(f"Ansible playbooks directory not found at {PLAYBOOKS_DIR}")
        all_ok = False

    print()
    if all_ok:
        ok(f"{Style.BOLD}All dependencies satisfied{Style.RESET}")
    else:
        fail("Some dependencies are missing — see warnings above")


