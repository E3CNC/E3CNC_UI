    if args.remote:
        inventory = _ensure_remote_inventory(args.remote)
    else:
        inventory = LOCAL_INVENTORY

    step(1, 1, "Running install playbook (agent + frontend + plugins + macros)")
    rc = run_ansible(INSTALL_PLAYBOOK, inventory, check=args.check, verbose=args.verbose)

    if rc == 0:
        ok("Install complete — refresh your browser or restart nginx")
    else:
        fail(f"Install failed (exit code {rc})")


